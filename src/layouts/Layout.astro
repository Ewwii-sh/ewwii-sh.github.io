---
import '../styles/global.css';
const canonicalURL = new URL(Astro.request.url, Astro.site).toString().replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/EwwiiLogo.png" />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		<link rel="canonical" href={Astro.canonicalURL} />
		<meta name="generator" content={Astro.generator} />

		<!-- Title and Description -->
		<title>Ewwii – Modern GTK Widget System for Linux Desktop Customization</title>
		<meta name="description" content="Ewwii is a powerful, extensible GTK widget system and modern alternative to eww. Build beautiful, interactive widgets for Hyprland, Wayland, X11 and Linux desktop customization." />

		<!-- Open Graph -->
		<meta property="og:title" content="Ewwii: A Widget System, better, powerful and extensible" />
		<meta property="og:description" content="The official website of ewwii, a GTK widget system for building interactive GUI components with flexibility and extensibility." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ewwii-sh.github.io" />
		<meta property="og:image" content="https://ewwii-sh.github.io/EwwiiLogo.png" />

		<meta name="robots" content="index, follow">
        <meta name="keywords" content="eww alternative, eww linux, linux widget system, gtk widgets, hyprland widgets, linux ricing, desktop customization" />

        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "SoftwareApplication",
          "name": "Ewwii",
          "description": "Modern extensible GTK widget system for Linux desktop customization",
          "url": "https://ewwii-sh.github.io",
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Linux",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
        })} />
	</head>
	<body>
		<slot />
	</body>
</html>

<script is:inline>
(function() {
  const html = document.documentElement;
  const savedTheme = localStorage.getItem("theme");
  const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;

  const theme = savedTheme || (prefersLight ? "light" : "dark");
  html.setAttribute("data-theme", theme);

  if (!savedTheme) {
    window.matchMedia("(prefers-color-scheme: light)").addEventListener("change", e => {
      html.setAttribute("data-theme", e.matches ? "light" : "dark");
    });
  }

  window.setTheme = function(newTheme) {
    html.setAttribute("data-theme", newTheme);
    localStorage.setItem("theme", newTheme);
  };
})();
</script>

<style>
html,
body {
	margin: 0;
	width: 100%;
	height: 100%;
}
</style>
