---
import '../styles/global.css';
const canonicalURL = new URL(Astro.request.url, Astro.site).toString().replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/EwwiiLogo.png" />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		<link rel="canonical" href={Astro.canonicalURL} />
		<meta name="generator" content={Astro.generator} />

		<!-- Title and Description -->
		<title>Ewwii: Modern GTK Widget System for Linux Desktop Customization</title>
		<meta
		    name="description"
			content="Ewwii is a GTK4-based widget system for building beautiful, interactive widgets and status bars in both X11 and Wayland based Window Managers and Desktop Environements."
		/>

		<!-- Open Graph -->
		<meta property="og:title" content="Ewwii: Widget System with focus on extensibility and simplicity." />
		<meta property="og:description" content="Ewwii is an extensibe, fully customizable widget system for building interactive widgets and status bars in both X11 and Wayland based Window Managers and Desktop Environments." />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Ewwii" />
		<meta property="og:url" content="https://ewwii-sh.github.io" />
		<meta property="og:image" content="https://ewwii-sh.github.io/Cover.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Meta Tags -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:domain" content="ewwii-sh.github.io" />
		<meta property="twitter:url" content="https://ewwii-sh.github.io" />
		<meta property="twitter:title" content="Ewwii" />
		<meta property="twitter:description" content="An extensive and customizable widget system for Linux based on GTK4." />

		<meta name="robots" content="index, follow">
        <meta name="keywords" content="eww alternative, eww linux, linux widget system, gtk widgets, hyprland widgets, linux ricing, desktop customization" />

        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "SoftwareApplication",
          "name": "Ewwii",
          "description": "Modern extensible GTK widget system for Linux desktop customization",
          "url": "https://ewwii-sh.github.io",
          "sameAs": [
            "https://github.com/Ewwii-sh/ewwii"
          ],
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Linux",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
        })} />
	</head>
	<body>
		<slot />
	</body>
</html>

<script is:inline>
(function() {
  const html = document.documentElement;
  const savedTheme = localStorage.getItem("theme");
  const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;

  const theme = savedTheme || (prefersLight ? "light" : "dark");
  html.setAttribute("data-theme", theme);

  if (!savedTheme) {
    window.matchMedia("(prefers-color-scheme: light)").addEventListener("change", e => {
      html.setAttribute("data-theme", e.matches ? "light" : "dark");
    });
  }

  window.setTheme = function(newTheme) {
    html.setAttribute("data-theme", newTheme);
    localStorage.setItem("theme", newTheme);
  };
})();
</script>

<style>
html,
body {
	margin: 0;
	width: 100%;
	height: 100%;
}
</style>
