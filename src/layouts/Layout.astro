---
import '../styles/global.css';
const canonicalURL = new URL(Astro.request.url, Astro.site).toString().replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/EwwiiLogo.png" />
		<link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
		<link rel="canonical" href={Astro.canonicalURL} />
		<meta name="generator" content={Astro.generator} />

		<!-- Title and Description -->
		<title>Ewwii: Modern GTK Widget System for Linux Desktop Customization</title>
		<meta
		    name="description"
			content="Ewwii is a GTK4-based widget system for building beautiful, interactive widgets and status bars in both X11 and Wayland based Window Managers and Desktop Environements."
		/>

		<!-- Open Graph -->
		<meta property="og:title" content="Ewwii: Extensible Widget System for Linux." />
		<meta property="og:description" content="A fully customizable widget system for building interactive widgets and status bars on X11 and Wayland." />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Ewwii" />
		<meta property="og:url" content="https://ewwii-sh.github.io" />
		<meta property="og:image" content="https://ewwii-sh.github.io/Cover.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter Meta Tags -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:domain" content="ewwii-sh.github.io" />
		<meta property="twitter:url" content="https://ewwii-sh.github.io" />
		<meta property="twitter:title" content="Ewwii" />
		<meta property="twitter:description" content="An extensive and customizable widget system for Linux based on GTK4." />

		<meta name="robots" content="index, follow">

        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "SoftwareApplication",
          "name": "Ewwii",
          "description": "Modern extensible GTK widget system for Linux desktop customization",
          "url": "https://ewwii-sh.github.io",
          "sameAs": [
            "https://github.com/Ewwii-sh/ewwii"
          ],
          "applicationCategory": "DeveloperApplication",
          "operatingSystem": "Linux",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
        })} />
	</head>
	<body>
		<slot />
	</body>
</html>

<script is:inline>
(function() {
  const html = document.documentElement;
  const savedTheme = localStorage.getItem("theme");
  const prefersLight = window.matchMedia("(prefers-color-scheme: light)").matches;

  const theme = savedTheme || (prefersLight ? "light" : "dark");
  html.setAttribute("data-theme", theme);

  if (!savedTheme) {
    window.matchMedia("(prefers-color-scheme: light)").addEventListener("change", e => {
      html.setAttribute("data-theme", e.matches ? "light" : "dark");
    });
  }

  window.setTheme = function(newTheme) {
    html.setAttribute("data-theme", newTheme);
    localStorage.setItem("theme", newTheme);
  };
})();
</script>

<script>
  let copyButtonLabel = "Copy";
  let codeBlocks = Array.from(document.querySelectorAll("pre"));

  for (let codeBlock of codeBlocks) {
    let wrapper = document.createElement("div");
    wrapper.style.position = "relative";

    let copyButton = document.createElement("button");
    copyButton.className = "copy-code";
    copyButton.innerHTML = copyButtonLabel;

    codeBlock.setAttribute("tabindex", "0");
    codeBlock.appendChild(copyButton);
    // wrap codebock with relative parent element
    codeBlock.parentNode.insertBefore(wrapper, codeBlock);
    wrapper.appendChild(codeBlock);

    copyButton.addEventListener("click", async () => {
      await copyCode(codeBlock, copyButton);
    });
  }

  async function copyCode(block, button) {
    let code = block.querySelector("code");
    let text = code.innerText;

    await navigator.clipboard.writeText(text);

    // visual feedback that task is completed
    button.innerText = "Copied!";

    setTimeout(() => {
      button.innerText = copyButtonLabel;
    }, 2000);
  }
</script>

<style>
html,
body {
	margin: 0;
	width: 100%;
	height: 100%;
}
</style>


<style is:global>
.copy-code {
    position: absolute;
    top: 0;
    right: 0;
    background-color: #444950;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    font-size: 0.75rem;
    line-height: 1rem;
    border-radius: 5px;
    margin: 10px;
    font-weight: bold;
}
</style>
