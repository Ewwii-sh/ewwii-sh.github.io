---
import { getCollection } from 'astro:content';
import Footer from '../../components/Footer.astro';
import Layout from '../../layouts/Layout.astro';

const allArticles = await getCollection('articles');
const sortedArticles = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const searchIndex = sortedArticles.map(article => ({
  id: article.id,
  title: article.data.title,
  description: article.data.description
}));
---

<Layout>
    <div class="max-w-6xl mx-auto text-center mb-8 pt-4">
      <a href="/" class="text-[var(--btn-primary-bg)] hover:underline transition text-center">
          ← Return Home (/)
      </a>
    </div>

    <div class="max-w-md mx-auto mb-10">
        <input 
         type="text" 
         id="article-search" 
         placeholder="Search articles..." 
         class="w-full px-4 py-2 rounded-lg border border-[var(--card-border)] bg-[var(--bg-color)] text-[var(--text-color)] focus:outline-none focus:border-[var(--btn-primary-bg)]"
         />
    </div>

    <section id="articles-directory" data-index={JSON.stringify(searchIndex)} class="py-10 px-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 max-w-6xl mx-auto">
          {sortedArticles.map(article => (
            <div id={`card-${article.id}`} class="article-card-item">
              <a href={`/articles/${article.id}/`} class="group block h-full">
                <div class="flex flex-col h-full p-6 rounded-xl border border-[var(--card-border)] bg-[var(--card-bg)] shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] transition-all duration-300 group-hover:-translate-y-1">
                  
                  <div class="flex-1">
                    <time class="block text-xs font-semibold uppercase tracking-wider text-[var(--text-gray-2)] mb-2">
                      {article.data.date.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>

                    <h3 class="text-xl font-bold mb-2 text-[var(--text-color)] group-hover:text-[var(--btn-primary-bg)] transition-colors">
                      {article.data.title}
                    </h3>
                    <p class="text-sm line-clamp-3 text-[var(--text-gray)]">
                        {article.data.description.length > 80 
                          ? article.data.description.slice(0, 80) + '...' 
                          : article.data.description}
                    </p>
                  </div>

                </div>
              </a>
            </div>
          ))}
        </div>
    </section>

  <Footer />
</Layout>

<script>
  import Fuse from 'https://esm.sh/fuse.js@7.0.0';

  const searchInput = document.getElementById('article-search') as HTMLInputElement;
  const container = document.getElementById('articles-directory');
  const cards = document.querySelectorAll('.article-card-item') as NodeListOf<HTMLElement>;

  if (searchInput && container) {
    const listData = JSON.parse(container.dataset.index || '[]');

    const fuse = new Fuse(listData, {
      keys: ['title', 'description'],
      threshold: 0.4,
    });

    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim();

      if (query === '') {
        cards.forEach(card => card.style.display = '');
        return;
      }

      const searchResults = fuse.search(query);
      const matchingIds = searchResults.map(result => result.item.id);

      cards.forEach(card => {
        const cardId = card.id.replace('card-', '');

        if (matchingIds.includes(cardId)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }
</script>
